# Studio dashboard configuration.
# Copy to .env.local for local development, and add the same variables in
# Vercel: Project Settings > Environment Variables.

# Password you type to sign in at /admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Random secret used to sign the admin session cookie.
# Generate one with: openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-string

# GitHub repository the dashboard commits to (owner/name).
GITHUB_REPO=libinside/abdishukri-portfolio

# Branch Vercel deploys from.
GITHUB_BRANCH=main

# GitHub token with write access to the repository's contents.
# Fine-grained token: Repository access > the repo above; Permissions >
# Contents: Read and write. See SETUP-DASHBOARD.md for steps.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# Vercel Blob store token for image uploads.
# When you connect a Blob store to the Vercel project, this is injected
# automatically. For local development, copy it from the Vercel dashboard
# (Storage > your Blob store > .env.local snippet).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx
